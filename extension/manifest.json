{
  "manifest_version": 3,
  "name": "Substack Notes Scheduler",
  "version": "1.0.0",
  "description": "Schedule Substack Notes to post at specific times",
  "permissions": ["storage", "alarms", "cookies"],
  "host_permissions": ["https://substack.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Substack Notes Scheduler"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
