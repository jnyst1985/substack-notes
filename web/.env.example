# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=32-byte-hex-string

# Threads OAuth (from Meta Developer Console)
